# PureChat local development environment.
# Copy this file to .env and replace every production secret before deploying.
# Do not commit real Supabase passwords, JWT secrets, storage keys, or OTP provider keys.

# Supabase PostgreSQL
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# App
NEXT_PUBLIC_APP_NAME="PureChat"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_ORIGIN="http://localhost:3000"
AUTH_COOKIE_NAME="purechat.session"

# Security
JWT_ACCESS_SECRET="81jZjfSqXX4CaygrYNbNkeYH5jhDTtLq3S9eljynV8YV4rFXCBdH95kxaIAzQ_3R"
JWT_REFRESH_SECRET="UTS2S5H6ZuXQhSGlEw31XNzBIA-G9os5USwuPsk9FhzMQXiAwm7kBSSPeNpvhPc8"
DATA_ENCRYPTION_KEY="3-MAZMrbGOiisHcOAHKBz2HyFwfT5YlJL0-VaGOLdhdOkEbciTzKf9sjZGwI1n03"

# Redis
# Local development falls back to in-memory rate limits if Redis is not running.
REDIS_URL="redis://localhost:6379"

# Uploads
STORAGE_DRIVER="local"
UPLOAD_DIR="./uploads"
UPLOAD_MAX_BYTES="26214400"

# S3-compatible storage for production only when STORAGE_DRIVER="s3"
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"

# Moderation
MODERATION_PROVIDER="local"
AI_MODERATION_API_KEY=""

# OTP
# Local development prints OTP codes in the server console.
OTP_PROVIDER="console"
OTP_FROM_EMAIL="no-reply@purechat.example"
OTP_FROM_PHONE="+10000000000"

# Realtime
SOCKET_IO_PATH="/api/socket"
NEXT_PUBLIC_SOCKET_IO_PATH="/api/socket"

# WebRTC
WEBRTC_STUN_URL="stun:stun.l.google.com:19302"
TURN_SERVER_URL=""
TURN_USERNAME=""
TURN_CREDENTIAL=""

# Seed
SEED_ADMIN_EMAIL="admin@purechat.local"
SEED_ADMIN_PASSWORD="Admin123456!"
